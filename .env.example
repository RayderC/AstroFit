# Required in production — generate with: openssl rand -hex 32
SESSION_SECRET=change_me_to_a_random_64_char_string_before_deploying

# Set to "true" if you terminate TLS in front of this app (recommended for internet-facing installs)
SESSION_COOKIE_SECURE=false

# Path to the SQLite database file (created automatically)
DATABASE_PATH=/config/comicorbit.db

# Paths where media files are stored (must match your Docker volume mounts)
MANGA_DIRECTORY=/Manga
COMICS_DIRECTORY=/Comics

# Path for config/migration files
CONFIG_DIRECTORY=/config
